<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
        <title id="pageTitle">JMedia Music</title>

        <!-- Scripts -->
        <script src="/js/theme-initializer.js"></script>
        <script src="/js/htmx.min.js"></script>
        <script defer src="/lib/alpine.min.js"></script>

        <!-- CSS -->
        <link rel="stylesheet" href="/css/bulma.min.css">
        <link rel="stylesheet" href="/lib/font-awesome/all.min.css">
        <link rel="stylesheet" href="/lib/primeicons.css">
        <link rel="stylesheet" href="/css/jmedia-unified.css">
        <link id="favicon" rel="icon" type="image/x-icon" href="logo.png">
    </head>
    <body class="music-page">

        <div class="plex-layout" id="plex-layout">
            <aside class="plex-sidebar" id="plex-sidebar">
                <div class="sidebar-brand">
                    <img src="/logo.png" alt="JMedia" class="sidebar-logo" onclick="location.href='/'">
                    <span class="sidebar-brand-text" onclick="location.href='/'">JMedia</span>
                    <button id="themeToggle" class="button is-ghost theme-toggle-btn"><i id="themeIcon" class="pi pi-sun"></i></button>
                    <button class="button is-ghost sidebar-toggle" id="toggleSidebarBtn"><i class="pi pi-bars"></i></button>
                </div>
                
                <nav class="sidebar-nav">
                    <div class="nav-group">
                        <p class="nav-label">Music Library</p>
                        <a href="javascript:void(0)" class="nav-item active" id="nav-music" onclick="loadMobilePlaylistSongs(0)">
                            <i class="pi pi-play-circle"></i> <span>Music</span>
                        </a>
                        <a href="/import" class="nav-item">
                            <i class="pi pi-download"></i> <span>Import</span>
                        </a>
                        <p class="nav-label mt-3">Playlists</p>
                        <div class="nav-sub-group" id="sidebarPlaylistList"></div>
                        <a href="javascript:void(0)" class="nav-sub-item create-playlist-btn" onclick="openCreatePlaylistModal()">
                            <i class="pi pi-plus"></i> <span>New Playlist</span>
                        </a>
                    </div>

                    <div class="nav-group">
                        <p class="nav-label">Personal</p>
                        <a href="javascript:void(0)" class="nav-item" id="nav-queue" onclick="switchToTab('queue')"><i class="pi pi-list"></i> <span>Queue</span></a>
                        <a href="javascript:void(0)" class="nav-item" id="nav-history" onclick="switchToTab('history')"><i class="pi pi-history"></i> <span>History</span></a>
                    </div>

                    <div class="nav-group">
                        <p class="nav-label">Video Library</p>
                        <a href="/video" class="nav-item"><i class="pi pi-video"></i> <span>Videos</span></a>
                    </div>

                    <div class="nav-group mt-auto">
                        <a href="/settings" class="nav-item"><i class="pi pi-cog"></i> <span>Settings</span></a>
                        <a href="javascript:void(0)" class="nav-item" id="openProfileModalBtn">
                            <i class="pi pi-user"></i> <span id="currentProfileName">Profile</span>
                        </a>
                    </div>
                </nav>
            </aside>

            <div class="plex-main">
                <header class="plex-header">
                    <div class="search-container">
                        <div class="control has-icons-left"><input class="input is-rounded plex-search" type="text" placeholder="Search songs..." id="mobileSearch"><span class="icon is-left"><i class="pi pi-search"></i></span></div>
                    </div>
                </header>

                <main class="plex-content">
                    <div class="music-main-wrapper" id="musicContentArea">
                        <div id="mobileSongList" class="mobile-song-list"></div>
                        <div id="mobileQueueContent" class="is-hidden"></div>
                        <div id="mobileHistoryContent" class="is-hidden"></div>
                    </div>

                    <div class="persistent-music-player">
                        <div class="mobile-player">
                            <div class="mobile-player-info">
                                <div class="mobile-player-artwork" id="songCoverImageContainer"><img id="songCoverImage" src="/logo.png" alt="Cover"></div>
                                <div class="mobile-player-details">
                                    <p id="songTitle" class="mobile-player-title">Loading...</p>
                                    <p id="songArtist" class="mobile-player-artist">Unknown Artist</p>
                                </div>
                            </div>
                            
                            <div class="mobile-player-controls">
                                <button id="shuffleBtn" class="mobile-btn"><i id="shuffleIcon" class="pi pi-sort-alt"></i></button>
                                <button id="prevBtn" class="mobile-btn"><i class="pi pi-step-backward"></i></button>
                                <button id="playPauseBtn" class="mobile-btn mobile-btn-primary"><i id="playPauseIcon" class="pi pi-play"></i></button>
                                <button id="nextBtn" class="mobile-btn"><i class="pi pi-step-forward"></i></button>
                                <button id="repeatBtn" class="mobile-btn"><i id="repeatIcon" class="pi pi-refresh"></i></button>
                            </div>

                            <div class="mobile-player-right-side">
                                <div class="mobile-volume-wrapper">
                                    <button id="volumeToggleBtn" class="mobile-btn"><i id="volumeIcon" class="pi pi-volume-up"></i></button>
                                    <div class="volume-slider-container">
                                        <input type="range" id="volumeProgressBar" class="vertical-volume" min="0" max="100" value="70">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mobile-progress-container">
                            <span id="currentTime">0:00</span>
                            <input type="range" id="playbackProgressBar" class="mobile-progress" min="0" max="100" value="0">
                            <span id="totalTime">0:00</span>
                        </div>
                    </div>
                </main>
            </div>
        </div>

        <audio id="audioPlayer" preload="auto"></audio>

        <!-- Modals & Menus -->
        <div id="customContextMenu" class="context-menu">
            <div class="context-menu-item" data-action="queue">Queue Song</div>
            <div class="context-menu-item" data-action="queue-similar">Queue Similar</div>
            <div class="context-menu-item has-submenu" data-action="playlist">
                Add to Playlist
                <div class="submenu" id="playlistSubMenu"></div>
            </div>
            <div class="context-menu-item" data-action="rescan">Re-Scan</div>
            <div class="context-menu-item" data-action="enrich">Update Metadata</div>
            <div class="context-menu-item has-text-danger" data-action="delete">Delete Song</div>
        </div>

        <div id="mobileContextMenu" class="mobile-context-menu" style="display: none;">
            <ul class="mobile-context-list">
                <li data-action="queue"><i class="pi pi-plus"></i> Queue Song</li>
                <li data-action="playlist"><i class="pi pi-folder-plus"></i> Add to Playlist</li>
                <li data-action="rescan"><i class="pi pi-sync"></i> Re-Scan</li>
                <li data-action="delete"><i class="pi pi-trash"></i> Delete Song</li>
            </ul>
            <div class="mobile-context-backdrop" onclick="window.hideMobileContextMenu()"></div>
        </div>

        <div id="playlistModal" class="modal">
            <div class="modal-background" onclick="this.parentElement.classList.remove('is-active')"></div>
            <div class="modal-card glass-modal">
                <header class="modal-card-head"><p class="modal-card-title">New Playlist</p></header>
                <div class="modal-card-body"><input class="input" type="text" id="newPlaylistName" placeholder="Playlist Name"></div>
                <footer class="modal-card-foot">
                    <button class="button is-success" onclick="confirmCreatePlaylist()">Create</button>
                    <button class="button" onclick="this.closest('.modal').classList.remove('is-active')">Cancel</button>
                </footer>
            </div>
        </div>

        <script src="/js/toast.js"></script>
        <script src="/js/songQueue.js"></script>
        <script src="/js/musicBar.js"></script>
        <script src="/js/mediaSession.js"></script>
        <script src="/js/profileManager.js"></script>

        <script>
            window.globalActiveProfileId = localStorage.getItem('activeProfileId') || '1';

            document.addEventListener('DOMContentLoaded', () => {
                if (window.Toast && typeof window.Toast.init === 'function') {
                    window.Toast.init();
                } else if (typeof ToastSystem !== 'undefined') {
                    window.Toast = new ToastSystem();
                    window.Toast.init();
                }

                const layout = document.getElementById('plex-layout');
                const toggleBtn = document.getElementById('toggleSidebarBtn');
                if (toggleBtn) toggleBtn.onclick = () => { layout.classList.toggle('collapsed'); localStorage.setItem('sidebarCollapsed', layout.classList.contains('collapsed')); };
                if (localStorage.getItem('sidebarCollapsed') === 'true') layout.classList.add('collapsed');

                const applySidebar = (pos) => {
                    if (pos === 'right') layout.classList.add('sidebar-right');
                    else layout.classList.remove('sidebar-right');
                };
                const cachedPos = localStorage.getItem('sidebarPosition');
                if (cachedPos) applySidebar(cachedPos);
                fetch(`/api/settings/${window.globalActiveProfileId}/sidebar-position`).then(r => r.json()).then(json => { if(json.data) { applySidebar(json.data); localStorage.setItem('sidebarPosition', json.data); } });

                loadMobilePlaylists();
                setTimeout(() => { loadMobilePlaylistSongs(0); }, 100);
            });

            function loadMobilePlaylists() {
                fetch(`/api/music/playlists/${window.globalActiveProfileId}`).then(r => r.json()).then(data => {
                    const list = document.getElementById('sidebarPlaylistList');
                    if (!list) return;
                    list.innerHTML = (data.data || data).map(p => `<a href="javascript:void(0)" class="nav-sub-item" id="nav-playlist-${p.id}" onclick="loadMobilePlaylistSongs(${p.id})"><span>${p.name}</span></a>`).join('');
                });
            }

            function loadMobilePlaylistSongs(id) {
                document.querySelectorAll('.nav-item, .nav-sub-item').forEach(el => el.classList.remove('active'));
                if (id === 0) document.getElementById('nav-music').classList.add('active');
                else document.getElementById(`nav-playlist-${id}`)?.classList.add('active');
                document.getElementById('mobileSongList').classList.remove('is-hidden');
                document.getElementById('mobileQueueContent').classList.add('is-hidden');
                document.getElementById('mobileHistoryContent').classList.add('is-hidden');
                if (window.htmx) window.htmx.ajax('GET', `/api/music/ui/mobile-tbody/${window.globalActiveProfileId}/${id}`, { target: '#mobileSongList', swap: 'innerHTML' });
            }

            function switchToTab(tab) {
                document.querySelectorAll('.nav-item, .nav-sub-item').forEach(el => el.classList.remove('active'));
                document.getElementById(`nav-${tab}`)?.classList.add('active');
                document.getElementById('mobileSongList').classList.add('is-hidden');
                document.getElementById('mobileQueueContent').classList.add('is-hidden');
                document.getElementById('mobileHistoryContent').classList.add('is-hidden');
                const targetId = tab === 'queue' ? 'mobileQueueContent' : 'mobileHistoryContent';
                const endpoint = tab === 'queue' ? 'mobile-queue-fragment' : 'mobile-history-fragment';
                document.getElementById(targetId).classList.remove('is-hidden');
                if (window.htmx) window.htmx.ajax('GET', `/api/music/ui/${endpoint}/${window.globalActiveProfileId}`, { target: `#${targetId}`, swap: 'innerHTML' });
            }

            function openCreatePlaylistModal() { document.getElementById('playlistModal').classList.add('is-active'); }
            async function confirmCreatePlaylist() {
                const name = document.getElementById('newPlaylistName').value.trim();
                if (!name) return;
                const res = await fetch(`/api/music/playlists/${window.globalActiveProfileId}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name }) });
                if (res.ok) { document.getElementById('playlistModal').classList.remove('is-active'); loadMobilePlaylists(); window.Toast.success('Playlist created'); }
            }

            // Globally accessible logout function
            window.handleLogout = async function() {
                try {
                    await fetch('/api/auth/logout', { 
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    window.location.href = '/login.html';
                } catch (error) {
                    window.location.href = '/login.html';
                }
            };
        </script>
        
        <!-- Profile Modal -->
<div id="profileModal" class="modal">
            <div class="modal-background"></div>
            <div class="modal-card glass-modal">
                <header class="modal-card-head">
                    <p class="modal-card-title">Manage Profiles</p>
                    <button class="delete" aria-label="close"></button>
                </header>
                <section class="modal-card-body">
                    <h5 class="title is-5">Current Profile: <span id="modalCurrentProfileName">Loading...</span></h5>
                    <div id="profileList" class="field is-grouped is-grouped-multiline is-justify-content-center"></div>
                    <hr>
                    <div class="field has-addons">
                        <div class="control is-expanded">
                            <input class="input" type="text" id="newProfileNameInput" placeholder="New profile name">
                        </div>
                        <div class="control">
                            <button class="button is-info" id="createProfileBtn">Create</button>
                        </div>
                    </div>
                    <button class="button is-danger is-fullwidth mt-4" id="deleteCurrentProfileBtn">Delete Profile</button>
                </section>
                <footer class="modal-card-foot" style="justify-content: space-between;">
                    <button class="button is-danger" id="logoutBtn" onclick="if(window.handleLogout) window.handleLogout(); else { fetch('/api/auth/logout', {method:'POST'}).then(()=>window.location.href='/login.html'); }">Logout</button>
                    <button class="button" onclick="this.closest('.modal').classList.remove('is-active')">Close</button>
                </footer>
            </div>
        </div>

        <div id="toast-container" style="position: fixed; top: 20px; right: 20px; z-index: 2000000;"></div>
    </body>
</html>
