<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title id="pageTitle">Spotdl/Yt-dlp Interface</title>
        <script src="/js/theme-initializer.js"></script>
        <link rel="stylesheet" href="/css/bulma.min.css"/>
        <link rel="stylesheet" href="/lib/primeicons.css">
        <link rel="stylesheet" href="/css/jmedia-unified.css"/>

        <script src="/js/htmx.min.js"></script>
        <script defer src="/lib/alpine.min.js"></script>
        <link id="favicon" rel="icon" type="image/x-icon" href="logo.png">

    </head>
    <body class="music-page">

        <audio id="audioPlayer" preload="auto"></audio>

        <script>
            window.globalActiveProfileId = localStorage.getItem('activeProfileId') || '1';
        </script>

        <div class="plex-layout" id="plex-layout">
            <aside class="plex-sidebar" id="plex-sidebar">
                <div class="sidebar-brand">
                    <img src="/logo.png" alt="JMedia" class="sidebar-logo" onclick="location.href='/'">
                    <span class="sidebar-brand-text" onclick="location.href='/'">JMedia</span>
                    <button id="themeToggle" class="button is-ghost theme-toggle-btn"><i id="themeIcon" class="pi pi-sun"></i></button>
                    <button class="button is-ghost sidebar-toggle" id="toggleSidebarBtn"><i class="pi pi-bars"></i></button>
                </div>
                
                <nav class="sidebar-nav">
                    <div class="nav-group">
                        <p class="nav-label">Music Library</p>
                        <a href="/" class="nav-item"><i class="pi pi-play-circle"></i> <span>Music</span></a>
                        <a href="/import" class="nav-item active"><i class="pi pi-download"></i> <span>Import</span></a>
                    </div>

                    <div class="nav-group">
                        <p class="nav-label">Video Library</p>
                        <a href="/video" class="nav-item"><i class="pi pi-video"></i> <span>Videos</span></a>
                    </div>

                    <div class="nav-group">
                        <p class="nav-label">Tools</p>
                        <a href="/settings#import-installation" class="nav-item admin-only"><i class="pi pi-wrench"></i> <span>Import Installation</span></a>
                    </div>

                    <div class="nav-group mt-auto">
                        <a href="/settings" class="nav-item"><i class="pi pi-cog"></i> <span>Settings</span></a>
                        <a href="javascript:void(0)" class="nav-item" id="openProfileModalBtn">
                            <i class="pi pi-user"></i> <span id="currentProfileName">Profile</span>
                        </a>
                    </div>
                </nav>
            </aside>

            <div class="plex-main">
                <header class="plex-header">
                    <div class="search-container">
                        <div class="control has-icons-left">
                            <input class="input is-rounded plex-search" type="text" placeholder="Search songs..." name="search" id="globalSearchInput"
                                   hx-get="/api/music/ui/search-results/{profileId}"
                                   hx-trigger="keyup changed delay:500ms, search"
                                   hx-target="#searchResultsContainer"
                                   hx-swap="innerHTML"
                                   hx-include="[name='search']"
                                   hx-indicator="#loadingRow">
                            <span class="icon is-left"><i class="pi pi-search"></i></span>
                        </div>
                        <div id="globalSearchDropdown" class="dropdown-menu" role="menu" style="display: none; position: absolute; top: 100%; left: 0; width: 100%; z-index: 1000;">
                            <div id="globalSearchDropdownLoadingIndicator" class="htmx-indicator has-text-centered py-2">
                                <i class="pi pi-spin pi-spinner" style="font-size: 1.5rem;"></i>
                            </div>
                            <div class="dropdown-content"
                                 id="searchSuggestionsDropdown"
                                 hx-trigger="keyup changed delay:300ms from:#globalSearchInput"
                                 hx-vals="js:{searchQuery: document.getElementById('globalSearchInput').value}"
                                 hx-target="this"
                                 hx-swap="innerHTML"
                                 hx-indicator="#globalSearchDropdownLoadingIndicator">
                            </div>
                        </div>
                    </div>
                </header>

                <main class="plex-content">
                    <div class="import-main-wrapper" style="padding: 1.5rem; max-height: calc(100vh - 180px); overflow-y: auto;">
                        <div class="glass-box" style="padding: 1.5rem;">
                            <h2 class="title is-4 mb-4">Import Interface</h2>
                            
                            <div id="externalAppWarning" class="notification is-info mb-4">
                                <button class="delete"></button>
                                <p class="mb-2">
                                    This page allows you to interface with the external 
                                    <a href="https://spotdl.rtfd.io/" target="_blank" class="has-text-weight-semibold">SpotDL</a> application.
                                </p>
                                <p class="mb-2">
                                    Please ensure that Python, SpotDL (installed via pip), and FFmpeg are correctly installed and configured on your system's PATH for this functionality to work.
                                </p>
                                <p>
                                    JMedia does not manage these external applications; it only provides a user interface to send commands to them.
                                </p>
                            </div>
                            <div id="spotdlWarningMessage" class="notification is-warning is-hidden mb-4">
                            </div>

                            <div class="field-group">
                                <div class="field">
                                    <label class="label" for="spotdlUrl">
                                        <span class="icon-text">
                                            <span class="icon"><i class="pi pi-music"></i></span>
                                            <span>Songs</span>
                                        </span>
                                    </label>
                                    <div class="control">
                                        <textarea class="textarea is-medium" id="spotdlUrl" 
                                                  placeholder="Single song: 'Song Title' or 'Artist - Title'

                                                  Multi-line list:
                                                  Max Sinàl,KingCrowney,Liv East - Intentions
                                                  Jend - I Know
                                                  NO CIGAR - Cool
                                                  Darius,WAYNE SNOW - Night Birds
                                                  Good Luck - Look at U

                                                  Or enter Spotify/YouTube URLs (playlists work)"></textarea>
                                    </div>
                                    <p class="help is-size-7">Single songs, albums, playlists, or multi-line song lists. Song lists support multiple artists separated by commas. Each line is treated as a separate song.</p>
                                </div>

                                <div class="field admin-only">
                                    <label class="label" for="downloadFolder">
                                        <span class="icon-text">
                                            <span class="icon"><i class="pi pi-folder"></i></span>
                                            <span>Download Folder</span>
                                        </span>
                                    </label>
                                    <div class="control">
                                        <input class="input is-medium" type="text" id="downloadFolder" 
                                               placeholder="e.g., C:\Music\SpotDL">
                                    </div>
                                    <p class="help is-size-7">Directory where downloaded files will be saved</p>
                                </div> 

                                <div class="field">
                                    <label class="label">
                                        <span class="icon-text">
                                            <span class="icon"><i class="pi pi-list"></i></span>
                                            <span>Playlist Selection (Optional)</span>
                                        </span>
                                    </label>
                                    <div class="columns is-mobile">
                                        <div class="column is-half">
                                            <div class="control">
                                                <div class="select is-fullwidth is-medium">
                                                    <select id="playlistSelect">
                                                        <option value="">-- Select existing playlist --</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="column is-half">
                                            <div class="control">
                                                <input class="input is-medium" type="text" id="newPlaylistName" 
                                                       placeholder="Or create new playlist">
                                            </div>
                                        </div>
                                    </div>
                                    <p class="help is-size-7">Add downloaded songs to an existing playlist or create a new one</p>
                                </div>

                                <div class="field admin-only">
                                    <label class="label">
                                        <span class="icon-text">
                                            <span class="icon"><i class="pi pi-cog"></i></span>
                                            <span>Advanced Import Configuration</span>
                                        </span>
                                    </label>

                                    <div class="card has-background-dark" x-data="{ showAdvanced: false }">
                                        <div class="card-content p-4">
                                            <div class="field">
                                                <button class="button is-info is-small is-fullwidth" @click="showAdvanced = !showAdvanced">
                                                    <span class="icon-text">
                                                        <span class="icon">
                                                            <i class="pi" :class="showAdvanced ? 'pi-chevron-up' : 'pi-chevron-down'"></i>
                                                        </span>
                                                        <span x-text="showAdvanced ? 'Hide Advanced Settings' : 'Show Advanced Settings'"></span>
                                                    </span>
                                                </button>
                                            </div>

                                            <div x-show="showAdvanced" x-transition>
                                                <div class="field">
                                                    <label class="label is-small">
                                                        <span class="icon-text">
                                                            <span class="icon"><i class="pi pi-cookie"></i></span>
                                                            <span>YouTube Cookies</span>
                                                        </span>
                                                    </label>
                                                    <div class="notification is-dark p-3">
                                                        <div class="field">
                                                            <label class="label is-small has-text-white">Upload Cookie File</label>
                                                            <div class="file has-name is-fullwidth" id="cookieFileUpload">
                                                                <label class="file-label">
                                                                    <input class="file-input" type="file" name="resume" id="cookieFileInput" accept=".txt">
                                                                    <span class="file-cta">
                                                                        <span class="file-icon">
                                                                            <i class="pi pi-upload"></i>
                                                                        </span>
                                                                        <span class="file-label">Choose file</span>
                                                                    </span>
                                                                    <span class="file-name" id="cookieFileName">No file selected</span>
                                                                </label>
                                                            </div>
                                                            <p class="help is-size-7 has-text-grey">Upload a cookies.txt file for YouTube downloads requiring authentication</p>
                                                        </div>
                                                        <div class="field">
                                                            <label class="label is-small has-text-white">Or Paste Cookie Content</label>
                                                            <div class="control">
                                                                <textarea class="textarea has-background-black has-text-white" 
                                                                          id="cookiesContent" rows="4" 
                                                                          placeholder="Paste your cookies.txt content here..."></textarea>
                                                            </div>
                                                        </div>
                                                        <div class="field is-grouped">
                                                            <div class="control">
                                                                <button class="button is-info is-small" id="uploadCookiesBtn">
                                                                    <span class="icon-text">
                                                                        <span class="icon"><i class="pi pi-upload"></i></span>
                                                                        <span>Save</span>
                                                                    </span>
                                                                </button>
                                                            </div>
                                                            <div class="control">
                                                                <button class="button is-danger is-small" id="deleteCookiesBtn">
                                                                    <span class="icon-text">
                                                                        <span class="icon"><i class="pi pi-trash"></i></span>
                                                                        <span>Delete</span>
                                                                    </span>
                                                                </button>
                                                            </div>
                                                        </div>
                                                        <div id="cookiesStatus" class="notification is-hidden mt-2 p-2"></div>
                                                    </div>
                                                </div>

                                                <div class="field">
                                                    <label class="label is-small">Download Sources</label>
                                                    <div class="columns">
                                                        <div class="column is-half">
                                                            <div class="field">
                                                                <label class="checkbox">
                                                                    <input type="checkbox" id="youtubeEnabled" checked>
                                                                    <span class="has-text-success">●</span> Enable YouTube (yt-dlp)
                                                                </label>
                                                            </div>
                                                            <div class="field">
                                                                <label class="checkbox">
                                                                    <input type="checkbox" id="spotdlEnabled" checked>
                                                                    <span class="has-text-success">●</span> Enable SpotDL
                                                                </label>
                                                            </div>
                                                            <div class="field">
                                                                <label class="checkbox">
                                                                    <input type="checkbox" id="enableSmartRateLimitHandling" checked>
                                                                    <span class="has-text-info">⚡</span> Smart rate limit handling
                                                                </label>
                                                                <p class="help is-size-7">Automatically switch sources on long rate limits (>1 hour)</p>
                                                            </div>
                                                            <div class="field">
                                                                <label class="checkbox">
                                                                    <input type="checkbox" id="fallbackOnLongWait" checked>
                                                                    <span class="has-text-warning">↩</span> Fallback on long wait
                                                                </label>
                                                                <p class="help is-size-7">Switch to fallback source if wait time exceeds max acceptable</p>
                                                            </div>
                                                        </div>
                                                        <div class="column is-half">
                                                            <div class="field">
                                                                <label class="label is-small">Primary Source</label>
                                                                <div class="select is-small is-fullwidth">
                                                                    <select id="primarySource">
                                                                        <option value="NONE">None</option>
                                                                        <option value="YOUTUBE">YouTube (yt-dlp)</option>
                                                                        <option value="SPOTDL">SpotDL</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                            <div class="field">
                                                                <label class="label is-small">Secondary Source (Fallback)</label>
                                                                <div class="select is-small is-fullwidth">
                                                                    <select id="secondarySource">
                                                                        <option value="NONE">None</option>
                                                                        <option value="SPOTDL">SpotDL</option>
                                                                        <option value="YOUTUBE">YouTube (yt-dlp)</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                            <div class="field">
                                                                <label class="label is-small">Switch Strategy</label>
                                                                <div class="select is-small is-fullwidth">
                                                                    <select id="switchStrategy">
                                                                        <option value="IMMEDIATELY">Switch immediately on failure</option>
                                                                        <option value="AFTER_FAILURES" selected>After X consecutive failures</option>
                                                                        <option value="ONLY_ON_RATE_LIMIT">Only on rate limit</option>
                                                                        <option value="SMART_ADAPTIVE">Smart adaptive switching</option>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="field">
                                                    <label class="label is-small">Retry & Timing Settings</label>
                                                    <div class="columns">
                                                        <div class="column">
                                                            <div class="field">
                                                                <label class="label is-small">Max Retry Attempts</label>
                                                                <div class="control">
                                                                    <input class="input is-small" type="number" id="maxRetryAttempts" 
                                                                           value="3" min="0" max="10">
                                                                </div>
                                                            </div>
                                                            <div class="field">
                                                                <label class="label is-small">Retry Wait Time (seconds)</label>
                                                                <div class="control">
                                                                    <input class="input is-small" type="number" id="retryWaitTime" 
                                                                           value="90" min="1" max="300">
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="column">
                                                            <div class="field">
                                                                <label class="label is-small">Failure Threshold</label>
                                                                <div class="control">
                                                                    <input class="input is-small" type="number" id="switchThreshold" 
                                                                           value="3" min="1" max="10">
                                                                </div>
                                                                <p class="help is-size-7">Number of failures before switching</p>
                                                            </div>
                                                            <div class="field">
                                                                <label class="label is-small">Max Acceptable Wait (minutes)</label>
                                                                <div class="control">
                                                                    <input class="input is-small" type="number" id="maxAcceptableWaitTime" 
                                                                           value="60" min="5" max="1440">
                                                                </div>
                                                                <p class="help is-size-7">Fallback if rate limit exceeds this time</p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                
                                                <div class="mt-4">
                                                    <hr>
                                                    <h6 class="title is-6 mb-3">
                                                        <span class="icon-text">
                                                            <span class="icon"><i class="pi pi-cog"></i></span>
                                                            <span>YouTube Advanced Options</span>
                                                        </span>
                                                    </h6>
                                                    
                                                    <div class="columns">
                                                        <div class="column is-half">
                                                            <div class="field">
                                                                <label class="checkbox">
                                                                    <input type="checkbox" id="youtubeForceIpv4">
                                                                    <span>Force IPv4</span>
                                                                </label>
                                                                <p class="help is-size-7">Helps with some 403 errors</p>
                                                            </div>
                                                            
                                                            <div class="field">
                                                                <label class="checkbox">
                                                                    <input type="checkbox" id="youtubeForceIpv6">
                                                                    <span>Force IPv6</span>
                                                                </label>
                                                                <p class="help is-size-7">Alternative to IPv4</p>
                                                            </div>
                                                            
                                                            <div class="field">
                                                                <label class="label is-small">User Agent</label>
                                                                <div class="control">
                                                                    <input class="input is-small" type="text" id="youtubeUserAgent" 
                                                                           placeholder="Mozilla/5.0 (Windows NT 10.0; Win64; x64)...">
                                                                </div>
                                                                <p class="help is-size-7">Custom browser user agent string</p>
                                                            </div>
                                                        </div>
                                                        <div class="column is-half">
                                                            <div class="field">
                                                                <label class="label is-small">Extractor Args</label>
                                                                <div class="control">
                                                                    <input class="input is-small" type="text" id="youtubeExtractorArgs" 
                                                                           placeholder="player_skip=webpage,configs">
                                                                </div>
                                                                <p class="help is-size-7">e.g., player_skip=webpage,configs</p>
                                                            </div>
                                                            
                                                            <div class="field">
                                                                <label class="label is-small">Browser Impersonation</label>
                                                                <div class="select is-small is-fullwidth">
                                                                    <select id="youtubeImpersonate">
                                                                        <option value="">None</option>
                                                                        <option value="chrome">Chrome</option>
                                                                        <option value="firefox">Firefox</option>
                                                                        <option value="safari">Safari</option>
                                                                    </select>
                                                                </div>
                                                                <p class="help is-size-7">TLS fingerprint bypass</p>
                                                            </div>
                                                            
                                                            <div class="field">
                                                                <label class="label is-small">Player Client</label>
                                                                <div class="select is-small is-fullwidth">
                                                                    <select id="youtubePlayerClient">
                                                                        <option value="">Auto (Default)</option>
                                                                        <option value="android">Android</option>
                                                                        <option value="tv">TV (Echo Show)</option>
                                                                        <option value="web">Web</option>
                                                                        <option value="web_safari">Web Safari</option>
                                                                    </select>
                                                                </div>
                                                                <p class="help is-size-7">Force specific YouTube client</p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="mt-3">
                                                        <hr>
                                                        <div class="columns is-vcentered">
                                                            <div class="column is-narrow">
                                                                <span class="is-size-7">Current yt-dlp version: </span>
                                                                <span id="ytdlpVersion" class="has-text-weight-bold is-size-7">Checking...</span>
                                                            </div>
                                                            <div class="column is-narrow">
                                                                <div class="field has-addons mb-0">
                                                                    <div class="control">
                                                                        <div class="select is-small">
                                                                            <select id="youtubeUpdateChannel">
                                                                                <option value="STABLE">Stable</option>
                                                                                <option value="NIGHTLY">Nightly</option>
                                                                                <option value="MASTER">Master</option>
                                                                            </select>
                                                                        </div>
                                                                    </div>
                                                                    <div class="control">
                                                                        <button class="button is-small is-info" id="updateYtDlpBtn">
                                                                            <span class="icon"><i class="pi pi-download"></i></span>
                                                                            <span>Update</span>
                                                                        </button>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="column">
                                                                <span id="ytdlpUpdateStatus" class="help is-size-7"></span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="field is-grouped mt-4">
                                                    <div class="control">
                                                        <button class="button is-success is-small" id="saveAdvancedConfigBtn" onclick="if(window.saveAdvancedConfiguration) window.saveAdvancedConfiguration(); else console.error('saveAdvancedConfiguration not found');">
                                                            <span class="icon-text">
                                                                <span class="icon"><i class="pi pi-save"></i></span>
                                                                <span>Save Configuration</span>
                                                            </span>
                                                        </button>
                                                    </div>
                                                    <div class="control">
                                                        <button class="button is-warning is-small" id="resetAdvancedConfigBtn">
                                                            <span class="icon-text">
                                                                <span class="icon"><i class="pi pi-refresh"></i></span>
                                                                <span>Reset to Defaults</span>
                                                            </span>
                                                        </button>
                                                    </div>
                                                    <div class="control">
                                                        <button class="button is-info is-small" id="testConfigurationBtn">
                                                            <span class="icon-text">
                                                                <span class="icon"><i class="pi pi-play"></i></span>
                                                                <span>Test Configuration</span>
                                                            </span>
                                                        </button>
                                                    </div>
                                                </div>

                                                <div id="configStatus" class="notification is-hidden mt-3">
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>  

                                <div class="field is-grouped mt-4">
                                    <div class="control">
                                        <button class="button is-warning is-medium" id="downloadBtn">
                                            <span class="icon-text">
                                                <span class="icon"><i class="pi pi-download"></i></span>
                                                <span>Find And Download</span>
                                            </span>
                                        </button>
                                    </div>
                                    <div class="control">
                                        <button class="button is-danger is-medium" id="cancelDownloadBtn" disabled>
                                            <span class="icon-text">
                                                <span class="icon"><i class="pi pi-times"></i></span>
                                                <span>Cancel</span>
                                            </span>
                                        </button>
                                    </div>
                                </div>

                                <div class="field mt-5">
                                    <label class="label">
                                        <span class="icon-text">
                                            <span class="icon"><i class="pi pi-terminal"></i></span>
                                            <span>Import Output</span>
                                        </span>
                                    </label>
                                    <div class="control">
                                        <textarea class="textarea has-background-black has-text-success" 
                                                  id="spotdlOutput" rows="12" readonly 
                                                  placeholder="Download progress and output will appear here..."></textarea>
                                    </div>
                                    <p class="help is-size-7">Real-time output from the download process</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="persistent-music-player">
                        <div class="mobile-player">
                            <div class="mobile-player-info">
                                <div class="mobile-player-artwork" id="songCoverImageContainer"><img id="songCoverImage" src="/logo.png" alt="Cover"></div>
                                <div class="mobile-player-details">
                                    <p id="songTitle" class="mobile-player-title">Loading...</p>
                                    <p id="songArtist" class="mobile-player-artist">Unknown Artist</p>
                                </div>
                            </div>
                            
                            <div class="mobile-player-controls">
                                <button id="shuffleBtn" class="mobile-btn"><i id="shuffleIcon" class="pi pi-sort-alt"></i></button>
                                <button id="prevBtn" class="mobile-btn"><i class="pi pi-step-backward"></i></button>
                                <button id="playPauseBtn" class="mobile-btn mobile-btn-primary"><i id="playPauseIcon" class="pi pi-play"></i></button>
                                <button id="nextBtn" class="mobile-btn"><i class="pi pi-step-forward"></i></button>
                                <button id="repeatBtn" class="mobile-btn"><i id="repeatIcon" class="pi pi-refresh"></i></button>
                            </div>

                            <div class="mobile-player-right-side">
                                <div class="mobile-volume-wrapper">
                                    <button id="volumeToggleBtn" class="mobile-btn"><i id="volumeIcon" class="pi pi-volume-up"></i></button>
                                    <div class="volume-slider-container">
                                        <input type="range" id="volumeProgressBar" class="vertical-volume" min="0" max="100" value="70">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mobile-progress-container">
                            <span id="currentTime">0:00</span>
                            <input type="range" id="playbackProgressBar" class="mobile-progress" min="0" max="100" value="0">
                            <span id="totalTime">0:00</span>
                        </div>
                    </div>
                </main>
            </div>
        </div>

        <div id="toast-container" style="position: fixed; top: 20px; right: 20px; z-index: 10000;"></div>
        <script src="/js/toast.js"></script>
        <script src="/js/musicBar.js"></script>
        <script src="/js/mediaSession.js"></script>
        <script src="/js/profileManager.js"></script>
        <script src="/js/songQueue.js"></script>
        <script src="/js/import.js"></script>

        <div id="profileModal" class="modal">
            <div class="modal-background" onclick="document.getElementById('profileModal').classList.remove('is-active');"></div>
            <div class="modal-card glass-modal">
                <header class="modal-card-head glass-modal-header">
                    <p class="modal-card-title">Manage Profiles</p>
                    <button class="delete" aria-label="close" onclick="document.getElementById('profileModal').classList.remove('is-active');"></button>
                </header>
                <section class="modal-card-body glass-modal-body">
                    <h5 class="title is-5">Current Profile: <span id="modalCurrentProfileName">Loading...</span></h5>
                    <h6 class="title is-6 mt-4">All Profiles:</h6>
                    <div class="field is-grouped is-grouped-multiline is-justify-content-center" id="profileList">
                    </div>
                    <hr>
                    <div class="field has-addons">
                        <div class="control is-expanded">
                            <input class="input" type="text" id="newProfileNameInput" placeholder="New Profile Name">
                        </div>
                        <div class="control">
                            <button class="button is-info" id="createProfileBtn">Create</button>
                        </div>
                    </div>
                    <button class="button is-danger is-fullwidth mt-4" id="deleteCurrentProfileBtn">Delete Current Profile</button>
                </section>
                <footer class="modal-card-foot glass-modal-footer">
                    <button class="button" onclick="document.getElementById('profileModal').classList.remove('is-active');">Close</button>
                </footer>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const layout = document.getElementById('plex-layout');
                const toggleBtn = document.getElementById('toggleSidebarBtn');
                
                if (toggleBtn) {
                    toggleBtn.onclick = () => {
                        layout.classList.toggle('collapsed');
                        localStorage.setItem('sidebarCollapsed', layout.classList.contains('collapsed'));
                    };
                }
                if (localStorage.getItem('sidebarCollapsed') === 'true') layout.classList.add('collapsed');

                const applySidebar = (pos) => {
                    if (pos === 'right') layout.classList.add('sidebar-right');
                    else layout.classList.remove('sidebar-right');
                };
                const cachedPos = localStorage.getItem('sidebarPosition');
                if (cachedPos) applySidebar(cachedPos);
                fetch(`/api/settings/${window.globalActiveProfileId}/sidebar-position`).then(r => r.json()).then(json => { if(json.data) { applySidebar(json.data); localStorage.setItem('sidebarPosition', json.data); } });
            });

            function updateHmxUrls() {
                const searchSuggestionsDropdown = document.getElementById('searchSuggestionsDropdown');
                if (searchSuggestionsDropdown) {
                    searchSuggestionsDropdown.setAttribute('hx-post', `/api/music/ui/search-suggestions/${window.globalActiveProfileId}`);
                }
            }

            updateHmxUrls();
            document.body.addEventListener('profileSwitched', updateHmxUrls);

            function uploadCookies() {
                const profileId = window.globalActiveProfileId;
                const cookiesContent = document.getElementById('cookiesContent').value.trim();

                if (!cookiesContent) {
                    showToast('Please enter cookies content', 'warning');
                    return;
                }

                const uploadBtn = document.getElementById('uploadCookiesBtn');
                const originalText = uploadBtn.innerHTML;
                uploadBtn.disabled = true;
                uploadBtn.innerHTML = '<span class="icon"><i class="pi pi-spin pi-spinner"></i></span> Saving...';

                fetch(`/api/settings/${profileId}/upload-cookies`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({cookiesContent: cookiesContent})
                })
                        .then(response => response.json())
                        .then(data => {
                            if (data.error) {
                                showToast('Failed to save cookies: ' + data.error, 'error');
                            } else {
                                showToast('Cookies file saved successfully', 'success');
                                document.getElementById('cookiesContent').value = '';
                            }
                        })
                        .catch(error => {
                            console.error('Error uploading cookies:', error);
                            showToast('Error uploading cookies', 'error');
                        })
                        .finally(() => {
                            uploadBtn.disabled = false;
                            uploadBtn.innerHTML = originalText;
                        });
            }

            function deleteCookies() {
                if (!confirm('Are you sure you want to delete the cookies file?')) {
                    return;
                }

                const profileId = window.globalActiveProfileId;
                const deleteBtn = document.getElementById('deleteCookiesBtn');
                const originalText = deleteBtn.innerHTML;
                deleteBtn.disabled = true;
                deleteBtn.innerHTML = '<span class="icon"><i class="pi pi-spin pi-spinner"></i></span> Deleting...';

                fetch(`/api/settings/${profileId}/cookies`, {
                    method: 'DELETE'
                })
                        .then(response => response.json())
                        .then(data => {
                            if (data.error) {
                                showToast('Failed to delete cookies: ' + data.error, 'error');
                            } else {
                                showToast('Cookies file deleted successfully', 'success');
                            }
                        })
                        .catch(error => {
                            console.error('Error deleting cookies:', error);
                            showToast('Error deleting cookies', 'error');
                        })
                        .finally(() => {
                            deleteBtn.disabled = false;
                            deleteBtn.innerHTML = originalText;
                        });
            }

            function uploadCookiesFile(file) {
                if (!file) {
                    console.error('No file provided');
                    return;
                }

                const profileId = window.globalActiveProfileId;
                console.log('Uploading cookie file:', file.name, 'for profile:', profileId);
                
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    const cookiesContent = e.target.result;
                    console.log('File content length:', cookiesContent.length);
                    
                    fetch(`/api/settings/${profileId}/upload-cookies`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({cookiesContent: cookiesContent})
                    })
                    .then(response => {
                        console.log('Response status:', response.status);
                        return response.json();
                    })
                    .then(data => {
                        console.log('Response data:', data);
                        if (data.error) {
                            showToast('Failed to upload cookies: ' + data.error, 'error');
                        } else {
                            showToast('Cookies file uploaded successfully', 'success');
                        }
                    })
                    .catch(error => {
                        console.error('Error uploading cookies file:', error);
                        showToast('Error uploading cookies file', 'error');
                    });
                };
                
                reader.onerror = function(e) {
                    console.error('FileReader error:', e);
                    showToast('Error reading file', 'error');
                };
                
                reader.readAsText(file);
            }

            document.addEventListener('DOMContentLoaded', function () {
                const uploadBtn = document.getElementById('uploadCookiesBtn');
                const deleteBtn = document.getElementById('deleteCookiesBtn');
                const cookieFileInput = document.getElementById('cookieFileInput');

                if (uploadBtn) {
                    uploadBtn.addEventListener('click', uploadCookies);
                }

                if (deleteBtn) {
                    deleteBtn.addEventListener('click', deleteCookies);
                }

                if (cookieFileInput) {
                    cookieFileInput.addEventListener('change', function(e) {
                        const file = e.target.files[0];
                        if (file) {
                            document.getElementById('cookieFileName').textContent = file.name;
                            uploadCookiesFile(file);
                        }
                    });
                }
            });

            document.body.addEventListener('htmx:beforeRequest', function (event) {
                let targetUrl = event.detail.path;

                if (typeof targetUrl !== 'string' || !targetUrl) {
                    return;
                }

                let newUrl = targetUrl;
                const currentProfileId = window.globalActiveProfileId;

                if (targetUrl.startsWith('/api/profiles')) {
                    return;
                }

                if (targetUrl.startsWith('/api/music/') || targetUrl.startsWith('/api/settings/')) {
                    const parts = targetUrl.split('/');
                    const module = parts[2];

                    if (module === 'music') {
                        const subModule = parts[3];

                        if (subModule === 'ui') {
                            if (parts[4] === 'search-suggestions') {
                                newUrl = `/api/music/ui/search-suggestions/${currentProfileId}`;
                            } else if (parts[4] === 'tbody' && parts[5] === '{playlistId}') {
                                newUrl = `/api/music/ui/tbody/${currentProfileId}`;
                            } else if (parts[4] === 'playlists-fragment' && parts[5] === '{profileId}') {
                                newUrl = `/api/music/ui/playlists-fragment/${currentProfileId}`;
                            } else if (parts[4] === 'playlist-view' && parts[5] === '{profileId}') {
                                newUrl = `/api/music/ui/playlist-view/${currentProfileId}`;
                            } else if (parts[4] === 'queue-fragment' && parts[5] === '{profileId}') {
                                newUrl = `/api/music/ui/queue-fragment/${currentProfileId}`;
                            } else if (parts[4] === 'add-to-playlist-dialog' && parts[5] === '{profileId}') {
                                newUrl = `/api/music/ui/add-to-playlist-dialog/${currentProfileId}`;
                            } else if (parts[4] !== currentProfileId) {
                                newUrl = `/api/music/ui/${currentProfileId}` + targetUrl.substring('/api/music/ui'.length);
                            }
                        } else if (subModule === 'playback') {
                            const action = parts[4];
                            if (action === 'queue-all' || action === 'select') {
                                newUrl = `/api/music/playback/${action}/${currentProfileId}/${parts[5]}`;
                            } else if (action === 'volume' || action === 'position') {
                                newUrl = `/api/music/playback/${action}/${currentProfileId}/${parts[5]}`;
                            } else {
                                if (parts.length < 5 || parts[5] !== currentProfileId) {
                                    newUrl = `${targetUrl}/${currentProfileId}`;
                                }
                            }
                        } else if (subModule === 'queue') {
                            const action = parts[4];
                            if (action === 'add' || action === 'skip-to' || action === 'remove') {
                                newUrl = `/api/music/queue/${action}/${currentProfileId}/${parts[5]}`;
                            } else if (action === 'clear') {
                                newUrl = `/api/music/queue/clear/${currentProfileId}`;
                            } else if (parts.length === 4) {
                                newUrl = `/api/music/queue/${currentProfileId}`;
                            }
                        } else if (subModule === 'playlists') {
                            if (parts.length >= 7 && parts[6] === 'toggle') {
                                if (parts.length < 8 || parts[7] !== currentProfileId) {
                                    newUrl = `${targetUrl}/${currentProfileId}`;
                                }
                            }
                        }
                    } else if (module === 'settings' && parts[3] === 'clearPlaybackHistory') {
                        if (parts.length < 5 || parts[4] !== currentProfileId) {
                            newUrl = `${targetUrl}/${currentProfileId}`;
                        }
                    }
                }
                if (newUrl !== targetUrl) {
                    event.detail.path = newUrl;
                    console.log('HTMX Request URL modified to:', event.detail.path);
                }
            });

            document.addEventListener('DOMContentLoaded', function () {
                const globalSearchInput = document.getElementById('globalSearchInput');
                const globalSearchDropdown = document.getElementById('globalSearchDropdown');

                function showDropdown() {
                    if (globalSearchInput && globalSearchInput.value.trim() !== '' && globalSearchDropdown && globalSearchDropdown.querySelector('.dropdown-item, .htmx-indicator')) {
                        globalSearchDropdown.style.display = 'block';
                    } else if (globalSearchDropdown) {
                        globalSearchDropdown.style.display = 'none';
                    }
                }

                function hideDropdown() {
                    setTimeout(() => {
                        if (globalSearchInput && !globalSearchInput.matches(':focus')) {
                            if (globalSearchDropdown) globalSearchDropdown.style.display = 'none';
                        }
                    }, 100);
                }

                if (globalSearchInput && globalSearchDropdown) {
                    globalSearchInput.addEventListener('focus', showDropdown);
                    globalSearchInput.addEventListener('keyup', showDropdown);
                    globalSearchInput.addEventListener('blur', hideDropdown);

                    globalSearchDropdown.addEventListener('mousedown', (event) => {
                        event.preventDefault();
                    });
                }

                document.body.addEventListener('click', function (event) {
                    if (event.target.closest('#clearSearchIcon')) {
                        if (globalSearchInput) globalSearchInput.value = '';
                        if (globalSearchDropdown) globalSearchDropdown.style.display = 'none';
                    }
                });

                document.body.addEventListener('htmx:afterSwap', function (event) {
                    if (event.detail.target.closest('#globalSearchDropdown .dropdown-content')) {
                        showDropdown();
                    }
                });

                const urlParams = new URLSearchParams(window.location.search);
                const searchQuery = urlParams.get('q');
                if (searchQuery && globalSearchInput) {
                    globalSearchInput.value = decodeURIComponent(searchQuery);
                    if (window.htmx) htmx.trigger(globalSearchInput, 'search');
                    history.replaceState(null, '', window.location.pathname);
                }
            });

            document.addEventListener('DOMContentLoaded', async () => {
                try {
                    console.log('[Admin Check] Starting...');
                    const adminRes = await fetch('/api/auth/is-admin');
                    console.log('[Admin Check] Response status:', adminRes.status);
                    const adminJson = await adminRes.json();
                    console.log('[Admin Check] Response:', adminJson);

                    const adminElements = document.querySelectorAll('.admin-only');
                    console.log('[Admin Check] Found admin-only elements:', adminElements.length);
                    adminElements.forEach((el, i) => {
                        console.log(`[Admin Check] Element ${i}:`, el, 'display:', el.style.display, 'class:', el.className);
                    });

                    if (!adminJson.data || !adminJson.data.isAdmin) {
                        console.log('[Admin Check] Not admin or no data - hiding admin-only elements');
                        adminElements.forEach(el => el.style.display = 'none');
                    } else {
                        console.log('[Admin Check] User is admin - showing admin-only elements');
                        adminElements.forEach(el => {
                            // Use flex for nav-items, block for others (like settings.js)
                            el.style.display = el.classList.contains('nav-item') ? 'flex' : 'block';
                            console.log('[Admin Check] Set display to ' + el.style.display + ' for:', el);
                        });
                    }
                } catch (e) {
                    console.error('[Admin Check] Error:', e);
                    document.querySelectorAll('.admin-only').forEach(el => {
                        el.style.display = 'none';
                    });
                }
            });

            const externalAppWarning = document.getElementById('externalAppWarning');
            const dismissWarningBtn = externalAppWarning ? externalAppWarning.querySelector('.delete') : null;
            const spotdlWarningShownKey = 'spotdlWarningShown';

            if (externalAppWarning) {
                if (localStorage.getItem(spotdlWarningShownKey) === 'true') {
                    externalAppWarning.classList.add('is-hidden');
                } else {
                    externalAppWarning.classList.remove('is-hidden');
                }

                if (dismissWarningBtn) {
                    dismissWarningBtn.addEventListener('click', () => {
                        externalAppWarning.classList.add('is-hidden');
                        localStorage.setItem(spotdlWarningShownKey, 'true');
                    });
                }
            }
        </script>
    </body>
</html>
